# Crypto Analyst Team — Environment Configuration
# Copy this file to .env and fill in your values.

# Required: Anthropic API key (get one at https://console.anthropic.com)
ANTHROPIC_API_KEY=your_key_here

# ── Coinbase (optional — public endpoints work without a key) ──────────────
# Adding a CDP API key gives you 3x higher rate limits (30 req/sec vs 10)
# and access to authenticated endpoints (best_bid_ask, account info).
# Get your key at: https://portal.cdp.coinbase.com/
# COINBASE_API_KEY=organizations/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx/apiKeys/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# COINBASE_API_SECRET=-----BEGIN EC PRIVATE KEY-----\nMIGk...\n-----END EC PRIVATE KEY-----\n

# ── Optional: enhances CHAIN analyst on-chain data ─────────────────────────
# Glassnode — on-chain analytics (MVRV, NUPL — free tier or $29/mo)
# GLASSNODE_API_KEY=

# Etherscan — ETH on-chain stats (free tier available)
# ETHERSCAN_API_KEY=

# CoinGecko — higher rate limits (free tier key available)
# COINGECKO_API_KEY=

# ── Optional paid upgrades ──────────────────────────────────────────────────
# See README.md for details on what each adds.

# Polygon.io — real-time data & websockets ($29/mo)
# POLYGON_API_KEY=

# Messari — fundamentals & research ($25/mo)
# MESSARI_API_KEY=

# CoinAPI — aggregated order book ($79/mo)
# COINAPI_KEY=

# Alpaca — trade execution (free tier available)
# ALPACA_API_KEY=
# ALPACA_SECRET_KEY=
# ALPACA_BASE_URL=https://paper-api.alpaca.markets
